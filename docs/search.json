 = {R package version 0.2.0},   url = {https://algocompsynth.github.io/consonaR/}, }"},{"path":"https://algocompsynth.github.io/consonaR/index.html","id":"consonar-consonance-based-algorithmic-composition","dir":"","previous_headings":"","what":"Consonance-based Algorithmic Composition","title":"Consonance-based Algorithmic Composition","text":"M. Edward (Ed) Borasky","code":""},{"path":"https://algocompsynth.github.io/consonaR/index.html","id":"overview","dir":"","previous_headings":"","what":"Overview","title":"Consonance-based Algorithmic Composition","text":"consonaR implements consonance-based algorithms composing music, based William Sethares’ Tuning, Timbre, Spectrum, Scale (Sethares 2013). consonaR part xen.assist project algorithmic xentonal composition.","code":""},{"path":[]},{"path":"https://algocompsynth.github.io/consonaR/reference/MIDI2freq.html","id":null,"dir":"Reference","previous_headings":"","what":"MIDI note number to frequency — MIDI2freq","title":"MIDI note number to frequency — MIDI2freq","text":"Converts vector MIDI note numbers vector corresponding frequencies. Note MIDI note numbers floating pointvalues - example, MIDI note number 60.5 quarter-tone middle C (60) middle C# (61).","code":""},{"path":"https://algocompsynth.github.io/consonaR/reference/MIDI2freq.html","id":"ref-usage","dir":"Reference","previous_headings":"","what":"Usage","title":"MIDI note number to frequency — MIDI2freq","text":"","code":"MIDI2freq(MIDI)"},{"path":"https://algocompsynth.github.io/consonaR/reference/MIDI2freq.html","id":"arguments","dir":"Reference","previous_headings":"","what":"Arguments","title":"MIDI note number to frequency — MIDI2freq","text":"MIDI numeric vector MIDI note numbers","code":""},{"path":"https://algocompsynth.github.io/consonaR/reference/MIDI2freq.html","id":"value","dir":"Reference","previous_headings":"","what":"Value","title":"MIDI note number to frequency — MIDI2freq","text":"numeric vector corresponding frequencies","code":""},{"path":"https://algocompsynth.github.io/consonaR/reference/MIDI2freq.html","id":"ref-examples","dir":"Reference","previous_headings":"","what":"Examples","title":"MIDI note number to frequency — MIDI2freq","text":"","code":"# quarter-tone scale   MIDI <- seq(60, 72, by = 0.5)   print(MIDI2freq(MIDI)) #>  [1] 261.6256 269.2918 277.1826 285.3047 293.6648 302.2698 311.1270 320.2437 #>  [9] 329.6276 339.2864 349.2282 359.4614 369.9944 380.8361 391.9954 403.4818 #> [17] 415.3047 427.4741 440.0000 452.8930 466.1638 479.8234 493.8833 508.3552 #> [25] 523.2511"},{"path":"https://algocompsynth.github.io/consonaR/reference/cents2frac.html","id":null,"dir":"Reference","previous_headings":"","what":"Cents to Fraction — cents2frac","title":"Cents to Fraction — cents2frac","text":"Converts vector cents vector corresponding ratios, expressed character vector vulgar fractions","code":""},{"path":"https://algocompsynth.github.io/consonaR/reference/cents2frac.html","id":"ref-usage","dir":"Reference","previous_headings":"","what":"Usage","title":"Cents to Fraction — cents2frac","text":"","code":"cents2frac(cents)"},{"path":"https://algocompsynth.github.io/consonaR/reference/cents2frac.html","id":"arguments","dir":"Reference","previous_headings":"","what":"Arguments","title":"Cents to Fraction — cents2frac","text":"cents numeric vector cents values","code":""},{"path":"https://algocompsynth.github.io/consonaR/reference/cents2frac.html","id":"value","dir":"Reference","previous_headings":"","what":"Value","title":"Cents to Fraction — cents2frac","text":"vector corresponding vulgar fractions","code":""},{"path":"https://algocompsynth.github.io/consonaR/reference/cents2frac.html","id":"ref-examples","dir":"Reference","previous_headings":"","what":"Examples","title":"Cents to Fraction — cents2frac","text":"","code":"print(cents2frac(seq(0, 1200, by = 100))) #>  [1] 1         1461/1379 1714/1527 1785/1501 635/504   3249/2434 1393/985  #>  [8] 2213/1477 1008/635  3002/1785 1527/857  2943/1559 2"},